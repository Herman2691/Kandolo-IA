# ============================================================
# KANDOLO AI — sécurité de l'hébergement
# ============================================================

# Force HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Empêche l'accès direct au fichier de config (la clé)
<Files "config.php">
  Require all denied
</Files>

# Empêche le téléchargement des bases de comptage
<FilesMatch "\.(sqlite|sqlite3|db)$">
  Require all denied
</FilesMatch>

# Désactive le listing des dossiers
Options -Indexes
